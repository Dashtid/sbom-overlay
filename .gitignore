# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.eggs/
*.egg

# Virtual envs
.venv/
venv/
env/

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
coverage.xml
.tox/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Project artifacts
sbom_inputs/
logs/
*.spdx.json
!tests/fixtures/**/*.spdx.json

# artifacts/: tracked structure, ignored contents.
# The three subdirs exist (via .gitkeep) so a fresh clone has the layout
# ready; the actual SBOMs and reports inside never get committed because
# they're typically customer-confidential.
artifacts/manual/*
artifacts/syft/*
artifacts/reports/*
!artifacts/manual/.gitkeep
!artifacts/syft/.gitkeep
!artifacts/reports/.gitkeep
